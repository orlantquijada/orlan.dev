+    This board persists your status in the browser (<code>localStorage</code>) so it survives reloads ŌĆö but it is <b>a mirror, not the source of truth</b>.
+    <code>plans/README.md</code> is canonical (the executor edits it). After a run, hit <b>Sync ŌåÉ README isn't automatic</b>: use <b>Copy README rows</b> to push this board's state back, or just click the statuses to match what the executor reported.
+  </div>
+
+  <h2>Reusable prompt ŌĆö paste in a fresh thread to run the next plan</h2>
+  <div class="prompt">
+    <div class="head"><b>Dependency-aware: skips a TODO whose prerequisite isn't DONE (009 before 010/011).</b>
+      <button class="primary" onclick="copyPrompt()">­¤ōŗ Copy prompt</button></div>
+    <pre id="prompt-box"></pre>
+  </div>
+
+  <h2>Plans <span style="font-weight:400;color:var(--dim);font-size:12px">ŌĆö click a status pill to cycle TODO ŌåÆ IN&nbsp;PROGRESS ŌåÆ DONE ŌåÆ BLOCKED</span></h2>
+  <table id="tbl">
+    <thead><tr>
+      <th>#</th><th>Plan</th><th>Pri</th><th>Effort</th><th>Status</th>
+    </tr></thead>
+    <tbody></tbody>
+  </table>
+  <div class="legend">Order = execution order. A row dims when it's waiting on an unfinished dependency. The <span style="color:var(--acc)">violet</span> row is the next runnable plan.</div>
+
+  <div class="bar">
+    <button class="primary" onclick="copyPrompt()">­¤ōŗ Copy execute-next prompt</button>
+    <button onclick="copyReadme()">Copy README rows (Markdown)</button>
+    <button onclick="copyJson()">Copy state (JSON)</button>
+    <button class="ghost" onclick="resetAll()">Reset</button>
+    <span id="msg"></span>
+  </div>
+
+  <div class="foot">
+    State key: <code>daily-plan-progress-v1</code> in localStorage. Statuses: TODO ┬Ę IN PROGRESS ┬Ę DONE ┬Ę BLOCKED.
+    Canonical status lives in <code>plans/README.md</code>; this board is for at-a-glance tracking + pushing updates back via the export buttons.
+  </div>
+</div>
+
+<textarea id="clip"></textarea>
+<script>
+const KEY = "daily-plan-progress-v1";
+const STATES = ["TODO","PROGRESS","DONE","BLOCKED"];
+const LABEL = { TODO:"TODO", PROGRESS:"IN PROGRESS", DONE:"DONE", BLOCKED:"BLOCKED" };
+
+// order matters = execution order
+const PLANS = [
+  { id:"009", file:"009-daily-test-runner.md",            title:"Vitest runner + characterization tests",  rmTitle:"Daily: Vitest runner + characterization tests",        pri:"P1", eff:"M", dep:null  },
+  { id:"010", file:"010-daily-february-today-fix.md",     title:"Fix February crash (getDailyDateToday)",   rmTitle:"Daily: fix February crash (`getDailyDateToday`)",      pri:"P1", eff:"S", dep:"009" },
+  { id:"011", file:"011-daily-ghost-likes-fix.md",        title:"Stop ghost likes; drop dead like helpers", rmTitle:"Daily: stop ghost likes; drop dead like helpers",      pri:"P1", eff:"S", dep:"009" },
+  { id:"012", file:"012-daily-show-actions-destructure.md", title:"Fix useShowActions swapped destructure", rmTitle:"Daily: fix `useShowActions` swapped destructure",       pri:"P2", eff:"S", dep:null  },
+  { id:"013", file:"013-daily-cleanup-metadata-hello.md", title:"Remove /hello route + fix root metadata",  rmTitle:"Daily: remove `/hello` route + fix root metadata",     pri:"P3", eff:"S", dep:null  },
+];
+
+function load(){ try { return JSON.parse(localStorage.getItem(KEY)) || {}; } catch { return {}; } }
+function save(s){ localStorage.setItem(KEY, JSON.stringify(s)); }
+let state = load();
+PLANS.forEach(p => { if(!STATES.includes(state[p.id])) state[p.id] = "TODO"; });
+
+function depMet(p){ return !p.dep || state[p.dep] === "DONE"; }
+function nextUp(){ return PLANS.find(p => state[p.id] === "TODO" && depMet(p)); }
+
+function render(){
+  const tb = document.querySelector("#tbl tbody");
+  tb.innerHTML = "";
+  const next = nextUp();
+  PLANS.forEach(p => {
+    const waiting = state[p.id] === "TODO" && !depMet(p);
+    const tr = document.createElement("tr");
+    if(next && p.id === next.id) tr.className = "next";
+    else if(waiting) tr.className = "waiting";
+    const depTxt = p.dep
+      ? `<span class="dep">depends on ${p.dep}${depMet(p) ? " Ō£ō" : ` ŌĆö Ōøö waiting (status: ${LABEL[state[p.dep]]})`}</span>`
+      : "";
+    const nextBadge = (next && p.id === next.id) ? `<span class="next-badge">NEXT</span>` : "";
+    const s = state[p.id];
+    tr.innerHTML = `
+      <td class="id"><a href="${p.file}">${p.id}</a></td>
+      <td class="title">${p.title}${nextBadge}${depTxt}</td>
+      <td><span class="pill cat">${p.pri}</span></td>
+      <td class="eff">${p.eff}</td>
+      <td><span class="st ${s}" data-id="${p.id}" title="click to cycle">${LABEL[s]}</span></td>`;
+    tb.appendChild(tr);
+  });
+  document.querySelectorAll(".st").forEach(el => el.addEventListener("click", () => cycle(el.dataset.id)));
+
+  const done = PLANS.filter(p => state[p.id] === "DONE").length;
+  const blocked = PLANS.filter(p => state[p.id] === "BLOCKED").length;
+  const pct = Math.round((done / PLANS.length) * 100);
+  document.querySelector("#m-done").textContent = done;
+  document.querySelector("#m-block").textContent = blocked;
+  document.querySelector("#m-next").textContent = next ? next.id : (done === PLANS.length ? "Ō£ō all done" : "ŌĆö");
+  document.querySelector("#pbar-fill").style.width = pct + "%";
+  document.querySelector("#pbar-pct").textContent = pct + "%";
+  document.querySelector("#pbar-txt").textContent = `${done} / ${PLANS.length} done` + (blocked ? ` ┬Ę ${blocked} blocked` : "");
+  document.querySelector("#prompt-box").textContent = promptText();
+}
+
+function cycle(id){
+  const i = STATES.indexOf(state[id]);
+  state[id] = STATES[(i + 1) % STATES.length];
+  save(state); render();
+}
+function resetAll(){ PLANS.forEach(p => state[p.id] = "TODO"); save(state); render(); flash("reset"); }
+
+function promptText(){
+  const n = nextUp();
+  const target = n ? `the next runnable daily plan (currently ${n.id})` : "the next runnable daily plan";
+  return `Execute ${target} in this repo.
+
+1. Read plans/README.md. Among plans 009ŌĆō013 (the apps/daily round), find the FIRST (top to bottom)
+   whose Status is TODO AND whose "Depends on" plan, if any, is already DONE. If none qualify, report
+   why (all done, or the only TODOs are blocked on an unfinished dependency) and stop.
+2. Immediately set that plan's Status to IN PROGRESS in plans/README.md (claim it) and tell me which you claimed.
+3. Read that plan file fully. Run its "Drift check"; if in-scope files drifted from the "Current state"
+   excerpts, set Status to BLOCKED (drift) and stop with a report.
+4. Follow the plan's Steps in order. After each, run its verification command and confirm the expected
+   result before continuing. Modify ONLY files in the plan's "In scope" list; touch nothing "Out of scope".
+5. If a STOP condition triggers, set Status to BLOCKED (<one-line reason>) and stop ŌĆö do not improvise.
+6. When all Done criteria pass, set Status to DONE.
+
+Do not commit, push, or open a PR unless I ask. Report: which plan, the git diff, each Done-criteria
+checkbox with its actual command output, and anything skipped or surprising. Run only ONE plan per invocation.`;
+}
+
+function readmeRows(){
+  return PLANS.map(p =>
+    `| ${p.id} | [${p.rmTitle}](${p.file}) | ${p.pri} | ${p.eff} | ${p.dep || "ŌĆö"} | ${LABEL[state[p.id]]} |`
+  ).join("\n");
+}
+
+function flash(t){ const m=document.querySelector("#msg"); m.textContent=t+" Ō£ō"; setTimeout(()=>m.textContent="",2000); }
+function copy(text,label){ const t=document.querySelector("#clip"); t.value=text; t.select();
+  try{ document.execCommand("copy"); }catch(e){}
+  if(navigator.clipboard){ navigator.clipboard.writeText(text).catch(()=>{}); }
+  flash(label+" copied"); }
+function copyPrompt(){ copy(promptText(),"Prompt"); }
+function copyReadme(){ copy(readmeRows(),"README rows"); }
+function copyJson(){ copy(JSON.stringify(state,null,2),"State JSON"); }
+
+render();
+</script>
+</body>
+</html>

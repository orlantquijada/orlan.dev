---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"ul">;

const props = Astro.props;
---

<ul {...props} class:list={['ul', props.class]}>
	<slot />
</ul>

<style>
	:global(.ul li) {
		position: relative;
		padding-inline-start: 2rem;
	}

	:global(.ul li::before) {
		position: absolute;
		top: 0;
		left: 0;
		color: var(--color-gray11, var(--gray11));
		content: "— ";
	}
</style>

---
import { GITHUB } from "@/utils/constants";
import LogoIcon from "./LogoIcon.astro";

type Props = {
	class?: string;
};

const { class: className } = Astro.props;
---

<footer
	class:list={['flex flex-col justify-center gap-4 px-6 pb-24', className]}
	transition:persist
>
	<div class="divider mb-6 h-4 w-full overflow-clip"></div>

	<ul class="flex gap-3">
		<li>
			<button class="theme-toggle" type="button">
				<LogoIcon />
			</button>
		</li>

		<li class="pointer-events-none select-none text-sm">•</li>
		<li>
			<a href="/work">Work</a>
		</li>
		<li>
			<a href="/notes">Notes</a>
		</li>
		<li>
			<a
				href="https://daily.orlan.dev"
				target="_blank"
				rel="noopener noreferrer"
				>Daily</a
			>
		</li>

		<li class="ml-auto">
			<a
				href="https://twitter.com/orlantquijada"
				target="_blank"
				rel="noopener noreferrer"
				>Twitter</a
			>
		</li>
		<li>
			<a href={GITHUB} target="_blank" rel="noopener noreferrer">GitHub</a>
		</li>
	</ul>

	<p class="text-sm text-gray11">
		This portfolio is Open Sourced! View it in
		<a
			href="https://www.figma.com/file/9DD7B7AKV2SN3sqo6cLWRB/Portfolio?node-id=610%3A3865"
			target="_blank"
			rel="noopener noreferrer"
			>Figma</a
		>
		{' '}or{' '}
		<a
			href="https://github.com/orlantquijada/orlan.dev"
			target="_blank"
			rel="noopener noreferrer"
			>Github</a
		>.
	</p>
</footer>

<style>
	li {
		display: flex;
		align-items: center;
		font-size: var(--text-sm);
		line-height: var(--tw-leading, var(--text-sm--line-height));
	}

	a {
		text-decoration: underline;
		text-decoration-thickness: 1px;
		text-decoration-color: var(--gray8);
		text-underline-offset: 4px;
	}

	a:hover {
		text-decoration-style: wavy;
		text-decoration-color: var(--gray10);
	}

	.divider {
		background: url("/waves2.svg");
	}

	html.dark .divider {
		filter: unset;
	}
</style>

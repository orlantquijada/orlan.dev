---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import NoteCard from "./NoteCard/NoteCard";

const notesData = await getCollection("notes");
const recentNotes = notesData
	.filter(({ data }) => !data.draft)
	.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
	.slice(0, 5)
	.map((note) => ({
		...note.data,
		href: `/notes/${note.id}`,
	}));
---

<section data-animate style="--stagger: 8">
	<h3 class="text-gray11 mb-6 text-sm">Notes</h3>
	<div class="notes-grid">
		{recentNotes.map((note) => (
      <NoteCard {...note} />
    ))}
		<a href="/notes" class="view-all-card">
			<span>View all notes</span>
			<Icon name="arrow-right" class="size-4" />
		</a>
	</div>
</section>

<style>
	/* Responsive equal-height grid. Masonry looked ragged for a handful of
	   variable-height cards (uneven columns + a big trailing gap), so the
	   recent-notes block uses a uniform grid instead: natural heights when
	   stacked on mobile, equal-height rows once there are multiple columns. */
	.notes-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
	}

	@media (min-width: 640px) {
		.notes-grid {
			grid-template-columns: repeat(2, 1fr);
			grid-auto-rows: 1fr;
		}
	}

	@media (min-width: 768px) {
		.notes-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.view-all-card {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		font-size: 0.875rem;
		color: var(--gray11);
		border: 1px dashed var(--gray6);
		border-radius: 0.5rem;
		transition:
			border-color 0.15s,
			color 0.15s,
			background-color 0.15s;
	}

	.view-all-card:hover {
		color: var(--gray12);
		background-color: var(--gray-a2);
		border-color: var(--gray8);
	}
</style>

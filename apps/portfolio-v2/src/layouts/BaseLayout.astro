---
import "@/styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import Fonts from "@/components/Fonts.astro";
import ThemeToggle from "@/components/ThemeToggle.astro";

export type Props = {
	title: string;
};

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width">
		<link rel="icon" href="/favicon.svg">
		<meta name="generator" content={Astro.generator}>
		<title>{title}</title>
		<ClientRouter />
		<slot name="head" />
		<Font cssVariable="--font-jetbrains-mono" preload />
		<Fonts />
		<ThemeToggle />
	</head>
	<body>
		<slot />
		<style is:global>
			/* add global styles + reset */
			*,
			*::after,
			*::before {
				box-sizing: border-box;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}
			* {
				min-width: 0;
			}
			::selection {
				/* background-color: var(--violetA5);
									        color: var(--violet12); */

				color: var(--selection-color);
				/* background-color: var(--violetA5);
									        color: var(--violet12); */

				background-color: var(--selection-bg);
			}
			html {
				display: grid;
				min-height: 100vh;
				/* biome-ignore lint/suspicious/noDuplicateProperties: progressive enhancement fallback for browsers without dvh support */
				min-height: 100dvh;
			}

			body {
				display: flex;
				flex-direction: column;

				min-height: 100%;
				font-family: var(--sans);
				color: var(--gray12);
				background-color: var(--gray1);
			}

			a,
			button {
				-webkit-tap-highlight-color: transparent;
			}

			::-webkit-scrollbar {
				width: 14px;
			}
			::-webkit-scrollbar-thumb {
				background-color: var(--gray-a6);
				background-clip: content-box;
				border: 4px solid transparent;
				border-radius: 14px;
			}
			::-webkit-scrollbar-thumb:hover {
				background-color: var(--gray-a7);
			}
			::-webkit-scrollbar-track {
				background: transparent;
			}
		</style>
	</body>
</html>
